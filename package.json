{
  "name": "zion-med",
  "version": "1.0.0",
  "description": "NARS Hospital - Hospital Management System (HMS)",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "clean:next": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});});console.log('Cleaned Next cache');\"",
    "dev:clean": "npm run clean:next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:direct": "node scripts/db-push-direct.mjs",
    "db:sync:admin-tables": "node scripts/db-execute-push-url.mjs scripts/sql/sync-system-settings-audit-log.sql",
    "db:apply-auth-token-version": "node scripts/db-execute-push-url.mjs scripts/apply-auth-token-version.sql",
    "db:ensure-admin": "node scripts/ensure-admin-credentials.mjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:service-catalog": "node scripts/seed-service-catalog.mjs",
    "db:indexes": "node scripts/add-indexes.mjs",
    "db:departments": "prisma db execute --file prisma/migrations/manual_departments.sql --schema prisma/schema.prisma",
    "create:pharmacist": "node scripts/create-pharmacist.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "playwright:install": "playwright install chromium"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@tanstack/react-query": "^5.100.9",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "next": "^16.2.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "eslint": "9.39.1",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.32",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
