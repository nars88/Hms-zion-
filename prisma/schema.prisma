generator client {
  provider      = "prisma-client-js"
  // Vercel build + Node serverless run on Linux (OpenSSL 3). "native" keeps local Windows/macOS dev working.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  password         String
  name             String
  role             UserRole
  phone            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  address          String?
  education        String?
  experience       Int?
  /// FK to `departments.id` (see manual migration); synced with departments.employee_ids JSON
  departmentId     String?    @map("department_id")
  generatedBills   Bill[]     @relation("BillGenerator")
  issuedExitPasses ExitPass[] @relation("ExitPassIssuer")
  visits           Visit[]

  @@map("users")
}

model Patient {
  id               String     @id @default(cuid())
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String
  phone            String
  email            String?
  address          String?
  emergencyContact String?
  emergencyPhone   String?
  bloodGroup       String?
  allergies        String?
  medicalHistory   String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  triageLevel      Int?
  sonarImage       String?
  sonarNotes       String?
  sonarStatus      String?
  bills            Bill[]
  exitPasses       ExitPass[]
  triages          Triage[]
  visits           Visit[]
  vitals           Vitals[]

  @@map("patients")
}

model Triage {
  id         String   @id @default(cuid())
  patientId  String
  symptoms   String
  aiAnalysis String?
  priority   Int      @default(3)
  vitalSigns Json?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("triages")
}

model Visit {
  id               String           @id @default(cuid())
  patientId        String
  doctorId         String?
  status           VisitStatus      @default(Waiting)
  chiefComplaint   String?
  diagnosis        String?
  prescription     String?
  notes            String?
  visitDate        DateTime         @default(now())
  dischargeDate    DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  finalDisposition String?
  bill             Bill?
  exitPass         ExitPass?
  medicationOrders MedicationOrder?
  doctor           User?            @relation(fields: [doctorId], references: [id])
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vitals           Vitals[]

  @@map("visits")
}

model Inventory {
  id               String            @id @default(cuid())
  drugName         String            @unique
  currentStock     Int               @default(0)
  unit             String            @default("unit")
  pricePerUnit     Decimal           @default(0) @db.Decimal(12, 2)
  minThreshold     Int               @default(10)
  expiryDate       DateTime?
  batchNumber      String?
  category         String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  medicationOrders MedicationOrder[]

  @@map("inventory")
}

model MedicationOrder {
  id           String                @id @default(cuid())
  visitId      String                @unique
  inventoryId  String?
  status       MedicationOrderStatus @default(PENDING)
  totalCost    Decimal               @default(0) @db.Decimal(10, 2)
  items        Json
  dispensedAt  DateTime?
  outOfStockAt DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  inventory    Inventory?            @relation(fields: [inventoryId], references: [id])
  visit        Visit                 @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("medication_orders")
}

model Bill {
  id              String    @id @default(cuid())
  visitId         String    @unique
  patientId       String
  generatedBy     String
  items           Json
  subtotal        Decimal   @db.Decimal(10, 2)
  tax             Decimal   @default(0) @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  total           Decimal   @db.Decimal(10, 2)
  paymentStatus   String    @default("Pending")
  paymentMethod   String?
  qrCode          String?   @unique
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  qrStatus        String    @default("LOCKED")
  generatedByUser User      @relation("BillGenerator", fields: [generatedBy], references: [id])
  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit           Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("bills")
}

model ExitPass {
  id           String    @id @default(cuid())
  visitId      String    @unique
  patientId    String
  issuedBy     String
  qrCode       String    @unique
  isValid      Boolean   @default(true)
  scannedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  issuedByUser User      @relation("ExitPassIssuer", fields: [issuedBy], references: [id])
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit        Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("exit_passes")
}

model Vitals {
  id          String   @id @default(cuid())
  patientId   String
  visitId     String?
  recordedBy  String?
  bp          String
  temperature Float
  heartRate   Int
  weight      Float
  recordedAt  DateTime @default(now())
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit       Visit?   @relation(fields: [visitId], references: [id])

  @@map("vitals")
}

model PriceSettings {
  id          String   @id @default(cuid())
  serviceType String   @unique
  serviceName String
  category    String
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("price_settings")
}

model departments {
  id               String   @id
  name             String   @unique
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  description      String?
  color            String?
  head_employee_id String?
  hod_name         String?
  hod_tag          String?
  employee_ids     Json?
}

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTION
  PHARMACIST
  ACCOUNTANT
  SECURITY
  RECEPTIONIST
  SECRETARY
  INTAKE_NURSE
  ER_NURSE
  LAB_TECH
  RADIOLOGY_TECH
}

enum VisitStatus {
  Waiting
  In_Consultation
  Billing
  Discharged
  READY_FOR_PHARMACY
  COMPLETED
  OUT_FOR_TEST
  READY_FOR_REVIEW
}

enum MedicationOrderStatus {
  PENDING
  DISPENSED
  OUT_OF_STOCK
  CLOSED
}
