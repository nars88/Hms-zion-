generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  password         String
  name             String
  role             UserRole
  phone            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  address          String?
  education        String?
  experience       Int?
  /// FK to `departments.id` (see manual migration); synced with departments.employee_ids JSON
  departmentId     String?    @map("department_id")
  generatedBills   Bill[]     @relation("BillGenerator")
  issuedExitPasses ExitPass[] @relation("ExitPassIssuer")
  visits           Visit[]

  @@map("users")
}

model Patient {
  id               String     @id @default(cuid())
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String
  phone            String
  email            String?
  address          String?
  emergencyContact String?
  emergencyPhone   String?
  bloodGroup       String?
  allergies        String?
  medicalHistory   String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  triageLevel      Int?
  sonarImage       String?
  sonarNotes       String?
  sonarStatus      String?
  bills            Bill[]
  exitPasses       ExitPass[]
  triages          Triage[]
  visits           Visit[]
  vitals           Vitals[]

  @@map("patients")
}

model Triage {
  id         String   @id @default(cuid())
  patientId  String
  symptoms   String
  aiAnalysis String?
  priority   Int      @default(3)
  vitalSigns Json?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("triages")
}

model Visit {
  id               String             @id @default(cuid())
  patientId        String
  doctorId         String?
  status           VisitStatus        @default(Waiting)
  chiefComplaint   String?
  diagnosis        String?
  prescription     String?
  notes            String?
  visitDate        DateTime           @default(now())
  dischargeDate    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  finalDisposition String?
  /// ER bed slot (1–12) for nurse/doctor bed boards
  bedNumber        Int?
  activity_history activity_history[]
  bill             Bill?
  emergencyTasks   EmergencyTask[]
  exitPass         ExitPass?
  medicationOrders MedicationOrder?
  doctor           User?              @relation(fields: [doctorId], references: [id])
  patient          Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vitals           Vitals[]

  @@index([status], map: "idx_visits_status")
  @@map("visits")
}

model VisitSequenceCounter {
  id         String            @id @default(cuid())
  keyDate    String            @map("key_date")
  kind       VisitSequenceKind
  lastNumber Int               @default(0) @map("last_number")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  @@unique([keyDate, kind], map: "idx_visit_sequence_counters_key_kind_unique")
  @@index([kind], map: "idx_visit_sequence_counters_kind")
  @@map("visit_sequence_counters")
}

model EmergencyTask {
  id                  String                     @id @default(uuid())
  visitId             String
  type                EmergencyTaskType
  title               String
  status              EmergencyTaskStatus        @default(PENDING)
  prescribedBy        String?
  executedBy          String?
  /// Optional billing integration metadata.
  billDepartment      String?
  billUnitPrice       Decimal?                   @db.Decimal(10, 2)
  billQuantity        Int?
  billedAt            DateTime?
  completedAt         DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  category            EmergencyTaskCategory      @default(NURSING)
  serviceCode         String?
  releasedBy          String?
  billingStatus       EmergencyTaskBillingStatus @default(NOT_BILLED)
  billItemId          String?
  orderedAt           DateTime?                  @default(now())
  startedAt           DateTime?
  releasedAt          DateTime?
  resultText          String?
  resultAttachmentUrl String?
  resultMeta          Json?
  service             ServiceCatalog?            @relation(fields: [serviceCode], references: [serviceCode])
  visit               Visit                      @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId], map: "idx_emergency_tasks_visit_id")
  @@index([status], map: "idx_emergency_tasks_status")
  @@index([type], map: "idx_emergency_tasks_type")
  @@index([category], map: "idx_emergency_tasks_category")
  @@index([serviceCode], map: "idx_emergency_tasks_service_code")
  @@index([billingStatus], map: "idx_emergency_tasks_billing_status")
  @@map("emergency_tasks")
}

model ServiceCatalog {
  id             String                @id @default(uuid())
  serviceCode    String                @unique @map("service_code")
  displayName    String                @map("display_name")
  department     ServiceDepartment
  taskCategory   EmergencyTaskCategory @map("task_category")
  billingUnit    BillingUnit           @default(PER_TASK) @map("billing_unit")
  basePrice      Decimal               @map("base_price") @db.Decimal(10, 2)
  currency       String                @default("IQD")
  isActive       Boolean               @default(true) @map("is_active")
  effectiveFrom  DateTime              @default(now()) @map("effective_from")
  effectiveTo    DateTime?             @map("effective_to")
  createdBy      String?               @map("created_by")
  updatedBy      String?               @map("updated_by")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  emergencyTasks EmergencyTask[]

  @@index([department], map: "idx_service_catalog_department")
  @@index([taskCategory], map: "idx_service_catalog_task_category")
  @@index([isActive], map: "idx_service_catalog_is_active")
  @@index([effectiveFrom, effectiveTo], map: "idx_service_catalog_effective_window")
  @@map("service_catalog")
}

model Inventory {
  id               String            @id @default(cuid())
  drugName         String            @unique
  currentStock     Int               @default(0)
  unit             String            @default("unit")
  pricePerUnit     Decimal           @default(0) @db.Decimal(12, 2)
  minThreshold     Int               @default(10)
  expiryDate       DateTime?
  batchNumber      String?
  category         String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  medicationOrders MedicationOrder[]

  @@map("inventory")
}

/// Single-row app branding. Use id `default`. `logo_url` stores a site path e.g. `/uploads/branding/logo-….png` (not hotlinked URLs).
model SystemSettings {
  id         String   @id
  systemName String   @default("NARS Hospital") @map("system_name")
  logoUrl    String?  @map("logo_url")
  updatedBy  String?  @map("updated_by")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// Append-only security / compliance trail for critical admin actions.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  userName  String   @map("user_name")
  userRole  String   @map("user_role")
  action    String
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)], map: "idx_audit_logs_created_at")
  @@index([userId], map: "idx_audit_logs_user_id")
  @@map("audit_logs")
}

model MedicationOrder {
  id           String                @id @default(cuid())
  visitId      String                @unique
  inventoryId  String?
  status       MedicationOrderStatus @default(PENDING)
  totalCost    Decimal               @default(0) @db.Decimal(10, 2)
  items        Json
  dispensedAt  DateTime?
  outOfStockAt DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  inventory    Inventory?            @relation(fields: [inventoryId], references: [id])
  visit        Visit                 @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("medication_orders")
}

model Bill {
  id              String    @id @default(cuid())
  visitId         String    @unique
  patientId       String
  generatedBy     String
  items           Json
  subtotal        Decimal   @db.Decimal(10, 2)
  tax             Decimal   @default(0) @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  total           Decimal   @db.Decimal(10, 2)
  paymentStatus   String    @default("Pending")
  paymentMethod   String?
  qrCode          String?   @unique
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  qrStatus        String    @default("LOCKED")
  generatedByUser User      @relation("BillGenerator", fields: [generatedBy], references: [id])
  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit           Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("bills")
}

model ExitPass {
  id           String    @id @default(cuid())
  visitId      String    @unique
  patientId    String
  issuedBy     String
  qrCode       String    @unique
  isValid      Boolean   @default(true)
  scannedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  issuedByUser User      @relation("ExitPassIssuer", fields: [issuedBy], references: [id])
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit        Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("exit_passes")
}

model Vitals {
  id              String   @id @default(cuid())
  patientId       String
  visitId         String?
  recordedBy      String?
  bp              String
  temperature     Float
  heartRate       Int
  weight          Float
  recordedAt      DateTime @default(now())
  /// SpO₂ % (ER Vitals Station)
  spo2            Float?
  /// e.g. "ER-Vitals" when recorded via ER Vitals Station (dedicated ER intake terminal)
  recordingSource String?
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit           Visit?   @relation(fields: [visitId], references: [id])

  @@map("vitals")
}

model PriceSettings {
  id          String   @id @default(cuid())
  serviceType String   @unique
  serviceName String
  category    String
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("price_settings")
}

model departments {
  id               String   @id
  name             String   @unique
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  description      String?
  color            String?
  head_employee_id String?
  hod_name         String?
  hod_tag          String?
  employee_ids     Json?
}

model activity_history {
  id          String   @id
  visitId     String
  actorUserId String?
  actorName   String?
  action      String
  details     String?
  createdAt   DateTime @default(now())
  visits      Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId, createdAt])
}

enum Department {
  CARDIOLOGY
  ORTHOPEDICS
  INTERNAL_MEDICINE
  PEDIATRICS
  GENERAL_SURGERY
  NEUROLOGY
  OPHTHALMOLOGY
  DERMATOLOGY
}

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTION
  PHARMACIST
  ACCOUNTANT
  SECURITY
  RECEPTIONIST
  SECRETARY
  INTAKE_NURSE
  ER_NURSE
  LAB_TECH
  RADIOLOGY_TECH
  /// Dedicated ER vitals-room terminal (not general intake / reception)
  ER_INTAKE_NURSE
}

enum VisitStatus {
  Waiting
  In_Consultation
  Billing
  Discharged
  READY_FOR_PHARMACY
  COMPLETED
  OUT_FOR_TEST
  READY_FOR_REVIEW
  /// ER Vitals Station saved — awaiting physician
  WAITING_FOR_DOCTOR
  /// ER Quick Reception — awaiting intake vitals / bed
  REGISTERED
  /// Intake referred patient — visible on ER doctor board
  WITH_DOCTOR
}

enum MedicationOrderStatus {
  PENDING
  DISPENSED
  OUT_OF_STOCK
  CLOSED
}

enum EmergencyTaskType {
  NURSE_TASK
  MED_ORDER
}

enum EmergencyTaskStatus {
  CREATED
  IN_PROGRESS
  PENDING
  COMPLETED
  RELEASED
  CANCELLED
}

enum EmergencyTaskCategory {
  NURSING
  DIAGNOSTIC_LAB
  DIAGNOSTIC_RADIOLOGY
  DIAGNOSTIC_SONAR
  DIAGNOSTIC_ECG
  BED_USAGE
}

enum EmergencyTaskBillingStatus {
  NOT_BILLED
  BILLED
}

enum ServiceDepartment {
  ER
  LAB
  RADIOLOGY
  SONAR
  ECG
  NURSING
}

enum BillingUnit {
  PER_TASK
  PER_HOUR
  PER_MINUTE
  PER_ITEM
}

enum VisitSequenceKind {
  CLINIC
  ER
}

enum VisitWorkflowState {
  WAITING
  TRIAGE
  DOCTOR_READY
  DISCHARGED
}
